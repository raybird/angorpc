# Wukong Docker 環境設定範例
# 複製此檔案為 .env 並填入你的值

# ── Host 使用者對齊（避免 volume 權限問題）──
USER_ID=1000
GROUP_ID=1000

# ── Host 工作目錄路徑 ──
# opencode 的工作空間會掛載到此路徑
WUKONG_HOST_WORKSPACE=./workspace

# ── AI Agent 設定 ──
# 預設 opencode run；若 opencode 不在 PATH 或需要特殊參數，請修改
WUKONG_AGENT_CMD=opencode run

# ── Telegram Bot（選用）──
# 可留空後透過 Web /settings 設定；若填入，env 會優先於 Web 設定。
# WUKONG_TG_TOKEN=your_bot_token_here
# WUKONG_TG_ALLOWED=your_chat_id_here

# ── Web Console（選用）──
# WUKONG_WEB_HOST=0.0.0.0
# WUKONG_WEB_PORT=8787
# WUKONG_WEB_TOKEN=your_secret_token_here

# ── 記憶與語意層 ──
# WUKONG_THINKING=1
# WUKONG_EMBED=0
